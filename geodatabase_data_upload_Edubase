    "import requests\n",
    "import pandas as pd\n",
    "import geopandas as gpd\n",
    "from shapely.geometry import Point\n",
    "from pyproj import CRS\n",
    "import subprocess\n",
    "import time\n",
    "from tqdm import tqdm"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "45611db1",
   "metadata": {},
   "source": [
    "# Configurations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "de593225",
   "metadata": {},
   "outputs": [],
   "source": [
    "# API endpoint\n",
    "base_url = \"https://naptan.api.dft.gov.uk/v1/StopPoints\"\n",
    "\n",
    "# PostGIS config\n",
    "ogr2ogr_path = r\"C:\\Program Files\\QGIS 3.34.11\\bin\\ogr2ogr.exe\"\n",
    "gpkg_path = r\"N:\\Geodatabase\\Raw_Data\\GPKG_temp_folder_for_geodatabse_upload/temp_upload.gpkg\"\n",
    "target_crs = CRS.from_epsg(27700)\n",
    "db_host = \"PRIORPSRV03\"\n",
    "db_name = \"gis\"\n",
    "db_port = \"5432\"\n",
    "db_schema = \"uk_new\"\n",
    "pg_conn_string = f\"PG:host={db_host} dbname={db_name} port={db_port}\"\n",
    "layer_name = \"mob_naptan_stops\""
   ]
  },
  {
   "cell_type": "markdown",
   "id": "303b4c17",
   "metadata": {},
   "source": [
    "# Fetch all active stops from the NaPTAN API"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "00762a7e",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fetch_all_active_stops():\n",
    "    all_data = []\n",
    "    page = 1\n",
    "    page_size = 1000\n",
    "\n",
    "    while True:\n",
    "        params = {\"status\": \"active\", \"page\": page, \"pageSize\": page_size}\n",
    "        response = requests.get(base_url, params=params)\n",
    "        if response.status_code != 200:\n",
    "            raise Exception(f\"Request failed on page {page}\")\n",
    "\n",
    "        page_data = response.json()\n",
    "        items = page_data.get(\"value\", [])\n",
    "        all_data.extend(items)\n",
    "\n",
    "        if not page_data.get(\"nextPage\"):\n",
    "            break\n",
    "        page += 1\n",
    "\n",
    "    return pd.DataFrame(all_data)\n",
    "\n",
    "df = fetch_all_active_stops()\n",
    "print(f\"Fetched {len(df)} active stops\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7e48c217",
   "metadata": {},
   "source": [
    "# Convert to GeoDataFrame and reproject"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "ab5f1592",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = df.dropna(subset=[\"latitude\", \"longitude\"])\n",
    "geometry = [Point(xy) for xy in zip(df[\"longitude\"], df[\"latitude\"])]\n",
    "\n",
    "gdf = gpd.GeoDataFrame(df, geometry=geometry, crs=\"EPSG:4326\")\n",
    "gdf = gdf.to_crs(target_crs)\n",
    "\n",
    "# Save to GeoPackage\n",
    "gdf.to_file(gpkg_path, driver=\"GPKG\", layer=layer_name)\n",
    "print(\"GeoPackage saved:\", gpkg_path)"
   ]
  },
